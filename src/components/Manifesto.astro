---
---

<section
  id="manifesto"
  class="relative bg-[var(--color-bone)] py-32 md:py-48"
>
  <div class="mx-auto grid max-w-[1600px] grid-cols-12 gap-6 px-6 md:px-10">
    <div class="col-span-12 md:col-span-2">
      <div class="sticky top-32 font-mono text-[10px] uppercase tracking-[0.3em] text-[var(--color-ink-soft)]">
        <div>§ 01</div>
        <div class="mt-1">— Manifesto</div>
      </div>
    </div>

    <div class="col-span-12 md:col-span-9 md:col-start-4">
      <h2
        class="font-display text-[clamp(2.5rem,6vw,6.5rem)] leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)] text-balance"
      >
        <span class="reveal-line"><span data-line>We don't make wine.</span></span>
        <span class="reveal-line"><span data-line class="italic text-[var(--color-clay)]">We refuse to make</span></span>
        <span class="reveal-line"><span data-line>almost everything else.</span></span>
      </h2>

      <div class="mt-20 grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-5">
          <p
            class="font-display text-xl leading-[1.3] text-[var(--color-ink)] md:text-2xl"
            data-fade
          >
            No oak chips. No selected yeasts. No enzymes, no acid corrections, no
            sugar adjustments, no reverse osmosis, no spinning cones, no
            cryoextraction. No new French barriques with their slow leak of
            vanilla into a liquid we did not put there.
          </p>
        </div>
        <div class="col-span-12 md:col-span-5 md:col-start-7">
          <p
            class="font-display text-xl leading-[1.3] text-[var(--color-ink)] md:text-2xl"
            data-fade
          >
            We harvest by hand, ferment in old clay and concrete, and bottle
            unfined and unfiltered. The vineyard is the recipe. The vintage is
            the chef. We are, at best, the kitchen porter who does not get in
            the way.
          </p>
        </div>
      </div>

      <div class="mt-24 flex items-center gap-4 font-mono text-[11px] uppercase tracking-[0.25em] text-[var(--color-ink-soft)]">
        <span class="h-px w-16 bg-[var(--color-ink-soft)]"></span>
        <span>— M. Halaris, winemaker</span>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce) {
    const lines = document.querySelectorAll<HTMLElement>("#manifesto [data-line]");
    const fades = document.querySelectorAll<HTMLElement>("#manifesto [data-fade]");

    ScrollTrigger.batch(lines, {
      onEnter: (els) => {
        gsap.to(els, {
          y: "0%",
          duration: 1.2,
          stagger: 0.12,
          ease: "expo.out",
        });
      },
      start: "top 85%",
    });

    ScrollTrigger.batch(fades, {
      onEnter: (els) => {
        gsap.to(els, {
          opacity: 1,
          y: 0,
          duration: 1,
          stagger: 0.1,
          ease: "expo.out",
        });
      },
      start: "top 90%",
    });
  }
</script>
