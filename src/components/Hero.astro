---
---

<section
  id="hero"
  class="relative min-h-[100svh] overflow-hidden bg-[var(--color-bone)] pt-24"
>
  <div class="grid-noise pointer-events-none absolute inset-0 opacity-[0.04]"></div>

  <div class="relative mx-auto grid h-full w-full max-w-[1600px] grid-cols-12 gap-6 px-6 md:px-10">
    <div class="col-span-12 flex items-end justify-between pb-6 font-mono text-[10px] uppercase tracking-[0.3em] md:col-span-12">
      <div class="flex items-center gap-3">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--color-clay)]"></span>
        <span>38.2146° N / 22.1234° E / 612m</span>
      </div>
      <div class="hidden md:block">Issue 01 — A natural wine project</div>
      <div>↓ scroll</div>
    </div>

    <div class="col-span-12 flex flex-col gap-6 md:col-span-12">
      <h1
        class="font-display text-[clamp(4.5rem,18vw,22rem)] leading-[0.82] tracking-[-0.06em]"
        data-hero-title
      >
        <span class="block overflow-hidden">
          <span class="block" data-line>par<span class="italic text-[var(--color-clay)]">·</span>dus</span>
        </span>
      </h1>

      <div class="grid grid-cols-12 items-end gap-6 pt-12">
        <div class="col-span-12 md:col-span-5">
          <p
            class="max-w-md text-pretty font-display text-2xl leading-[1.15] text-[var(--color-ink)] md:text-3xl"
            data-fade
          >
            A natural wine project from the western slopes of a forgotten Aegean island. <span class="italic">Low intervention, high altitude, single-vineyard.</span>
          </p>
        </div>

        <div class="col-span-6 md:col-span-3 md:col-start-7">
          <dl class="space-y-3 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-soft)]">
            <div class="flex justify-between border-b border-[var(--color-ink)]/15 pb-2">
              <dt>Founded</dt>
              <dd>2019</dd>
            </div>
            <div class="flex justify-between border-b border-[var(--color-ink)]/15 pb-2">
              <dt>Hectares</dt>
              <dd>3.2</dd>
            </div>
            <div class="flex justify-between border-b border-[var(--color-ink)]/15 pb-2">
              <dt>Altitude</dt>
              <dd>612m</dd>
            </div>
            <div class="flex justify-between">
              <dt>Cases / yr</dt>
              <dd>1,800</dd>
            </div>
          </dl>
        </div>

        <div class="col-span-6 md:col-span-3">
          <div class="aspect-[3/4] overflow-hidden bg-[var(--color-ink)]">
            <img
              src="https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?auto=format&fit=crop&w=900&q=80"
              alt="Vineyard at dusk"
              class="h-full w-full object-cover grayscale contrast-110"
              loading="eager"
            />
          </div>
          <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-soft)]">
            Fig. 01 — Vines at sundown
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute right-0 top-1/2 hidden -translate-y-1/2 [writing-mode:vertical-rl] font-mono text-[10px] uppercase tracking-[0.4em] text-[var(--color-ink-soft)]/60 md:block">
    Pardus Wine Project · A natural wine project · MMXXVI ·
  </div>
</section>

<script>
  import gsap from "gsap";

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce) {
    const lines = document.querySelectorAll<HTMLElement>("#hero [data-line]");
    const fades = document.querySelectorAll<HTMLElement>("#hero [data-fade]");

    // Initial state is defined in CSS via html.js .reveal-line > span / [data-fade]
    // so there's no flash of visible content before this script runs.

    const tl = gsap.timeline({ defaults: { ease: "expo.out" } });
    tl.to(lines, { y: "0%", duration: 1.4, stagger: 0.1, delay: 0.2 }).to(
      fades,
      { opacity: 1, y: 0, duration: 1.1, stagger: 0.08 },
      "-=0.9",
    );
  }
</script>
