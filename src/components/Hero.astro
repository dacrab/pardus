---
---

<section
  id="hero"
  class="relative min-h-screen overflow-hidden bg-bone"
>
  <div class="grid-noise pointer-events-none absolute inset-0 opacity-[0.04]"></div>

  <div class="relative mx-auto flex min-h-screen w-full max-w-[1600px] flex-col items-start justify-center px-6 md:px-10">
    <h1
      class="font-display text-7xl leading-[0.82] tracking-[-0.06em] md:text-8xl lg:text-9xl xl:text-[14rem]"
      data-hero-title
    >
      <span class="block overflow-hidden">
        <span class="block" data-line>par<span class="text-clay">·</span>dus</span>
      </span>
    </h1>

    <p
      class="mt-4 max-w-lg text-balance font-display text-lg leading-[1.15] text-ink md:mt-6 md:text-xl lg:text-2xl"
      data-fade
    >
      A natural wine project from the western slopes of a forgotten Aegean island. <span class="italic">Low intervention, high altitude, single-vineyard.</span>
    </p>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { shouldAnimate } from "../utils/animations";

  if (shouldAnimate()) {
    const lines = document.querySelectorAll<HTMLElement>("#hero [data-line]");
    const fades = document.querySelectorAll<HTMLElement>("#hero [data-fade]");

    const tl = gsap.timeline({ defaults: { ease: "expo.out" } });
    tl.to(lines, { y: "0%", duration: 1.4, stagger: 0.1, delay: 0.2 }).to(
      fades,
      { opacity: 1, y: 0, duration: 1.1, stagger: 0.08 },
      "-=0.9",
    );
  }
</script>
