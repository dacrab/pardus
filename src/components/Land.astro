---
const facts = [
  { k: "Soil", v: "Schist, limestone, decomposed clay" },
  { k: "Aspect", v: "North-west, exposed to the meltemi" },
  { k: "Vines", v: "Avg. 67 years, massale selection" },
  { k: "Varietals", v: "Assyrtiko, Malagousia, Mavrotragano" },
];
---

<section id="land" class="relative bg-[var(--color-ink)] py-32 text-[var(--color-bone)] md:py-48">
  <div class="mx-auto grid max-w-[1600px] grid-cols-12 gap-6 px-6 md:px-10">
    <div class="col-span-12 md:col-span-2">
      <div class="font-mono text-[10px] uppercase tracking-[0.3em] opacity-60">
        <div>§ 02</div>
        <div class="mt-1">— The Land</div>
      </div>
    </div>

    <div class="col-span-12 md:col-span-9 md:col-start-4">
      <p class="font-mono text-[11px] uppercase tracking-[0.3em] opacity-60">
        Coordinates — 38.2146° N, 22.1234° E
      </p>
      <h2
        class="mt-6 font-display text-[clamp(2.5rem,6vw,6rem)] leading-[0.95] tracking-[-0.04em] text-balance"
      >
        <span class="reveal-line"><span data-line>Six hundred and twelve metres above</span></span>
        <span class="reveal-line"><span data-line class="italic text-[var(--color-clay)]">a sea that does not forgive.</span></span>
      </h2>
    </div>

    <div class="col-span-12 mt-20 grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-7">
        <div class="aspect-[4/5] overflow-hidden md:aspect-[16/11]">
          <img
            src="https://images.unsplash.com/photo-1559849912-3c0a4abe34c2?auto=format&fit=crop&w=1400&q=80"
            alt="Terraced vineyard on a hillside"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.2em] opacity-60">
          Fig. 02 — Terraces above the village of Ano Vouno
        </p>
      </div>

      <div class="col-span-12 grid grid-cols-2 gap-6 md:col-span-4 md:col-start-9">
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1568213816046-0ee1c42bd559?auto=format&fit=crop&w=700&q=80"
            alt="Old stone wall in vineyard"
            class="h-full w-full object-cover grayscale"
            loading="lazy"
          />
        </div>
        <div class="aspect-[3/4] overflow-hidden md:mt-16">
          <img
            src="https://images.unsplash.com/photo-1474649107449-ea4c014b7c9f?auto=format&fit=crop&w=700&q=80"
            alt="Hands holding grapes"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="col-span-2 mt-6">
          <img
            src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1200&q=80"
            alt="Grapes on the vine"
            class="aspect-[16/9] w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <div class="col-span-12 mt-24 grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
      {
        facts.map((f) => (
          <div class="border-t border-[var(--color-bone)]/20 pt-4">
            <div class="font-mono text-[10px] uppercase tracking-[0.3em] opacity-50">
              {f.k}
            </div>
            <div class="mt-2 font-display text-xl leading-snug">{f.v}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce) {
    const lines = document.querySelectorAll<HTMLElement>("#land [data-line]");
    gsap.set(lines, { y: "110%" });
    ScrollTrigger.batch(lines, {
      onEnter: (els) =>
        gsap.to(els, { y: "0%", duration: 1.1, stagger: 0.1, ease: "expo.out" }),
      start: "top 85%",
    });
  }
</script>
