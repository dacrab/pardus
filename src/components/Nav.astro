---
const links = [
  { label: "Manifesto", href: "#manifesto" },
  { label: "The Land", href: "#land" },
  { label: "Wines", href: "#wines" },
  { label: "Process", href: "#process" },
  { label: "Visit", href: "#visit" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 flex items-center justify-between px-6 py-5 mix-blend-difference text-[var(--color-bone)] md:px-10"
>
  <a href="#" class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.3em]">
    <span class="block h-2 w-2 rounded-full bg-[var(--color-clay)]"></span>
    Pardus / MMXXVI
  </a>

  <nav class="hidden items-center gap-8 font-mono text-[11px] uppercase tracking-[0.25em] md:flex">
    {
      links.map((l) => (
        <a href={l.href} class="opacity-70 transition hover:opacity-100">
          {l.label}
        </a>
      ))
    }
  </nav>

  <a
    href="#visit"
    class="group flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.25em] opacity-90 transition hover:opacity-100"
  >
    <span>Reserve a tasting</span>
    <span class="block h-px w-6 bg-current transition-all group-hover:w-10"></span>
  </a>
</header>
