---
const items = [
  "Wild ferment",
  "No fining",
  "No filtration",
  "Single vineyard",
  "Hand harvest",
  "Old vines",
  "Low sulfur",
  "Biodynamic",
];
---

<section class="border-y border-[var(--color-ink)]/15 bg-[var(--color-ink)] py-6 text-[var(--color-bone)]">
  <div class="marquee" data-marquee>
    {
      [0, 1].map(() => (
        <div class="marquee__track font-display text-4xl italic md:text-6xl">
          {items.map((item) => (
            <span class="flex items-center gap-12 whitespace-nowrap">
              {item}
              <span class="text-[var(--color-clay)]">✺</span>
            </span>
          ))}
        </div>
      ))
    }
  </div>
</section>
