---
const year = new Date().getFullYear();
---

<footer class="relative bg-[var(--color-ink)] py-20 text-[var(--color-bone)] md:py-32">
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-7">
        <p class="font-mono text-[10px] uppercase tracking-[0.3em] opacity-50">
          § 06 — Stay in touch
        </p>
        <h2
          class="mt-6 font-display text-[clamp(3rem,9vw,9rem)] leading-[0.9] tracking-[-0.05em]"
        >
          <span class="reveal-line"><span data-line>A letter,</span></span>
          <span class="reveal-line"><span data-line class="italic text-[var(--color-clay)]">twice a year,</span></span>
          <span class="reveal-line"><span data-line>no more.</span></span>
        </h2>

        <form
          class="mt-12 flex max-w-xl flex-col gap-3 border-b border-[var(--color-bone)]/30 pb-4 md:flex-row md:items-center"
          data-fade
        >
          <input
            type="email"
            placeholder="your@email"
            class="w-full flex-1 bg-transparent py-3 font-mono text-base text-[var(--color-bone)] placeholder:opacity-30 focus:outline-none"
            required
          />
          <button
            type="submit"
            class="group flex items-center gap-2 self-start font-mono text-[11px] uppercase tracking-[0.3em] text-[var(--color-bone)] md:self-auto"
          >
            Subscribe
            <span class="block h-px w-8 bg-current transition-all group-hover:w-14"></span>
          </button>
        </form>
        <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.2em] opacity-40">
          Vintage reports · allocation notices · cellar-door news. Unsubscribe anytime.
        </p>
      </div>

      <div class="col-span-6 mt-12 md:col-span-2 md:col-start-9 md:mt-0">
        <p class="font-mono text-[10px] uppercase tracking-[0.3em] opacity-50">Cellar</p>
        <ul class="mt-6 space-y-3 font-display text-lg">
          <li><a href="#wines" class="hover:text-[var(--color-clay)]">Wines</a></li>
          <li><a href="#process" class="hover:text-[var(--color-clay)]">Process</a></li>
          <li><a href="#visit" class="hover:text-[var(--color-clay)]">Visit</a></li>
        </ul>
      </div>
      <div class="col-span-6 mt-12 md:col-span-2 md:mt-0">
        <p class="font-mono text-[10px] uppercase tracking-[0.3em] opacity-50">Channels</p>
        <ul class="mt-6 space-y-3 font-display text-lg">
          <li><a href="#" class="hover:text-[var(--color-clay)]">Instagram</a></li>
          <li><a href="#" class="hover:text-[var(--color-clay)]">Substack</a></li>
          <li><a href="mailto:hello@pardus.wine" class="hover:text-[var(--color-clay)]">Email</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-32 flex flex-col items-start justify-between gap-6 border-t border-[var(--color-bone)]/15 pt-8 font-mono text-[10px] uppercase tracking-[0.3em] opacity-50 md:flex-row md:items-center">
      <div>© {year} Pardus Wine Project · All vintages bottled unfined & unfiltered</div>
      <div class="flex items-center gap-6">
        <span>38.2146° N</span>
        <span class="opacity-30">·</span>
        <span>22.1234° E</span>
        <span class="opacity-30">·</span>
        <span>612m</span>
      </div>
    </div>

    <div class="mt-20 overflow-hidden">
      <div
        class="font-display text-[clamp(6rem,28vw,32rem)] leading-[0.8] tracking-[-0.07em] text-[var(--color-bone)]/[0.08]"
        aria-hidden="true"
      >
        par·dus
      </div>
    </div>
  </div>
</footer>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce) {
    const lines = document.querySelectorAll<HTMLElement>("footer [data-line]");
    const fades = document.querySelectorAll<HTMLElement>("footer [data-fade]");
    gsap.set(lines, { y: "110%" });
    gsap.set(fades, { opacity: 0, y: 20 });
    ScrollTrigger.batch(lines, {
      onEnter: (els) =>
        gsap.to(els, { y: "0%", duration: 1.1, stagger: 0.1, ease: "expo.out" }),
      start: "top 90%",
    });
    ScrollTrigger.batch(fades, {
      onEnter: (els) =>
        gsap.to(els, {
          opacity: 1,
          y: 0,
          duration: 0.9,
          stagger: 0.1,
          ease: "expo.out",
        }),
      start: "top 90%",
    });
  }
</script>
